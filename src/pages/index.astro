---
import Layout from '../layouts/Layout.astro';
import IssueCard from '../components/IssueCard.astro';
import { recentIssues } from '../data/issues';
---

<Layout title="Hanna's Happenings">
  <h1>Hanna's Happenings</h1>
  <h2>Welcome!</h2>
  <p>
    <i>Hanna's Happenings</i> is my monthly personal newsletter. New issues are released on the last day of each month, and often focus on a specific theme or project.
  </p>
  <p>
    I share art and musings from my creative pursuits, hobbies, and everyday life. If you like figuring out how things work, want inspiration for your next creative project, or want to keep in touch, you're in the right place!
  </p>

  <h2>Recent Issues</h2>
  <div class="issue-grid">
    {recentIssues.map((issue) => (
      <IssueCard issue={issue} />
    ))}
  </div>

  <p><a href="/archive">Browse the full archive →</a></p>

  <h2>Subscribe</h2>
  <blockquote>Get an email when new issues drop each month. No ads, no sponsors. Just me making things and sharing about them.</blockquote>
  <form
    action="https://buttondown.com/api/emails/embed-subscribe/hannashappenings"
    method="post"
    class="subscribe-form"
    novalidate
  >
    <div class="form-group">
      <label for="bd-email">Email address <span class="required">*</span></label>
      <input
        type="email"
        name="email"
        id="bd-email"
        required
        aria-describedby="email-error"
        autocomplete="email"
      />
      <div id="email-error" class="error-message" role="alert" aria-live="polite"></div>
    </div>
    
    <div class="form-group">
      <label for="bd-first-name">First name</label>
      <input
        type="text"
        name="first_name"
        id="bd-first-name"
        autocomplete="given-name"
      />
    </div>
    
    <div class="form-group">
      <label for="bd-last-name">Last name</label>
      <input
        type="text"
        name="last_name"
        id="bd-last-name"
        autocomplete="family-name"
      />
    </div>
    
    <input
      type="submit"
      value="Subscribe"
      class="subscribe-button"
      disabled
    />
    
    <p class="powered-by">
      <a href="https://buttondown.com/refer/hannashappenings" target="_blank" rel="noopener">
        Powered by Buttondown.
      </a>
    </p>
  </form>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const form = document.querySelector('.subscribe-form');
      const emailInput = document.getElementById('bd-email');
      const submitButton = document.querySelector('.subscribe-button');
      const emailError = document.getElementById('email-error');

      function validateEmail(email) {
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return emailRegex.test(email);
      }

      function updateSubmitButton() {
        const email = emailInput.value.trim();
        const isValidEmail = validateEmail(email);
        
        submitButton.disabled = !isValidEmail;
        
        if (email && !isValidEmail) {
          emailError.textContent = 'Please enter a valid email address';
          emailInput.setAttribute('aria-invalid', 'true');
        } else {
          emailError.textContent = '';
          emailInput.setAttribute('aria-invalid', 'false');
        }
      }

      emailInput.addEventListener('input', updateSubmitButton);
      emailInput.addEventListener('blur', updateSubmitButton);

      // Initial validation
      updateSubmitButton();
    });
  </script>
</Layout>