---
import Navigation from '../components/Navigation.astro';

interface Props {
  title?: string;
}

const { title = "Hanna's Happenings" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/H.jpg" />
		<link rel="icon" href="/H.jpg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Navigation />
		<main class="content-container">
			<slot />
		</main>
		<footer class="footer">
			<p>&copy; 2025 Hanna D. Clements. All rights reserved.</p>
		</footer>
	</body>
</html>

<style is:global>
	/* CSS Variables */
	:root {
		--primary-color: #016698;
		--primary-dark: #0d4d6f;
		--text-dark: #212529;
		--text-muted: #6c757d;
		--bg-light: #f8f9fa;
		--border-color: #e9ecef;
		--accent-color: #016698;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		font-family: 'Georgia', serif;
		font-size: 16px;
		line-height: 1.6;
		color: var(--text-dark);
		background: linear-gradient(135deg, #e8f4f8 0%, #d1e8f0 100%);
		min-height: 100vh;
	}

	body {
		width: 100%;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		background-color: #fff;
	}

	.content-container {
		flex: 1;
		max-width: 900px;
		margin: 0 auto;
		padding: 3rem 2rem;
		width: 100%;
	}

	h1 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		color: var(--accent-color);
		letter-spacing: -0.5px;
	}

	h2 {
		font-size: 1.75rem;
		font-weight: 600;
		margin: 2rem 0 1rem 0;
		color: var(--text-dark);
		border-bottom: 3px solid var(--primary-color);
		display: inline-block;
		padding-bottom: 0.5rem;
	}

	h3 {
		font-size: 1.25rem;
		font-weight: 600;
		margin: 1.5rem 0 0.75rem 0;
		color: var(--text-dark);
	}

	p {
		margin-bottom: 1.25rem;
		line-height: 1.75;
		color: var(--text-dark);
	}

	em {
		font-style: italic;
		color: var(--accent-color);
		font-weight: 500;
	}

	strong {
		font-weight: 700;
	}

	a {
		color: var(--primary-color);
		text-decoration: none;
		transition: all 0.3s ease;
		border-bottom: 1px dotted var(--primary-color);
	}

	a:hover {
		color: var(--primary-dark);
		border-bottom-color: var(--primary-dark);
	}

	ul, ol {
		margin-left: 2rem;
		margin-bottom: 1.25rem;
	}

	li {
		margin-bottom: 0.75rem;
		line-height: 1.7;
	}

	.footer {
		background: linear-gradient(to right, var(--bg-light), #e8eef2);
		border-top: 2px solid var(--border-color);
		padding: 2rem;
		text-align: center;
		color: var(--text-muted);
		margin-top: auto;
		font-size: 0.9rem;
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		html {
			font-size: 15px;
		}

		.content-container {
			padding: 1.5rem;
		}

		h1 {
			font-size: 2rem;
		}

		h2 {
			font-size: 1.5rem;
		}

		h3 {
			font-size: 1.1rem;
		}

		ul, ol {
			margin-left: 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.content-container {
			padding: 1rem;
		}

		h1 {
			font-size: 1.75rem;
		}

		h2 {
			font-size: 1.25rem;
		}

		p {
			font-size: 0.95rem;
		}
	}
</style>
